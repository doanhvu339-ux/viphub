-- Nút TP / Giữ để quay lại
local tpButton = createButton("TP / Giữ để quay lại")
local holdStart = 0

local function teleportCharacter(pos)
    local character = player.Character
    if not character or not character:FindFirstChild("HumanoidRootPart") then return end
    local hrp = character.HumanoidRootPart
    local seat = nil

    for _, s in pairs(workspace:GetDescendants()) do
        if s:IsA("Seat") or s:IsA("VehicleSeat") then
            if s.Occupant == character:FindFirstChildOfClass("Humanoid") then
                seat = s
                break
            end
        end
    end

    if seat then
        local wasAnchored = seat.Anchored
        seat.Anchored = true
        seat.CFrame = CFrame.new(pos)
        task.wait(0.05)
        seat.Anchored = wasAnchored
    else
        hrp.CFrame = CFrame.new(pos)
    end
end

tpButton.MouseButton1Down:Connect(function()
    holdStart = tick()
end)

tpButton.MouseButton1Up:Connect(function()
    if tpLocked then
        tpButton.Text = "TP đã bị khóa!"
        task.delay(1.2, function()
            tpButton.Text = "TP / Giữ để quay lại"
        end)
        return
    end

    if not savedPosition then
        tpButton.Text = "Chưa đặt vị trí!"
        task.delay(1.2, function()
            tpButton.Text = "TP / Giữ để quay lại"
        end)
        return
    end

    local character = player.Character
    if not character or not character:FindFirstChild("HumanoidRootPart") then return end
    local hrp = character.HumanoidRootPart
    local holdTime = tick() - holdStart

    if holdTime < 0.5 then
        teleportCharacter(savedPosition)
        tpButton.Text = "Đã TP!"
        task.delay(0.8, function()
            tpButton.Text = "TP / Giữ để quay lại"
        end)
    else
        local originalPos = hrp.Position
        teleportCharacter(savedPosition)
        for i = 4, 1, -1 do
            tpButton.Text = "Quay lại sau: "..i.."s"
            task.wait(1)
        end
        teleportCharacter(originalPos)
        tpButton.Text = "TP / Giữ để quay lại"
    end
end)

-- Lắng nghe chat để lock/unlock TP
TextChatService.OnIncomingMessage = function(message)
    local sender = message.TextSource and message.TextSource.Name
    local content = message.Text
    if sender == "ehfphvg362" then -- chỉ user này
        local targetName = content:match("lock tp%s+(%S+)")
        if targetName and targetName == player.Name then
            tpLocked = true
        end
        local unlockTarget = content:match("unlocktp%s+(%S+)")
        if unlockTarget and unlockTarget == player.Name then
            tpLocked = false
        end
    end
end
