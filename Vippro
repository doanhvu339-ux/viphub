-- TOGGLE FUNCTION

local function toggle(parent,text,y,flag,callback)

    local b = Instance.new("TextButton")
    b.Parent = parent
    b.Size = UDim2.new(0,220,0,40)
    b.Position = UDim2.new(0,20,0,y)
    b.Font = Enum.Font.GothamBold
    b.TextSize = 14
    b.TextColor3 = Color3.fromRGB(0,0,0)

    Instance.new("UICorner", b)

    local function refresh()

        if settings[flag] then
            b.Text = text.." : ON"
            b.BackgroundColor3 = Color3.fromRGB(220,220,220)
        else
            b.Text = text.." : OFF"
            b.BackgroundColor3 = Color3.fromRGB(245,245,245)
        end
    end

    b.MouseButton1Click:Connect(function()

        settings[flag] = not settings[flag]

        refresh()

        if callback then
            callback(settings[flag])
        end
    end)

    refresh()
end

