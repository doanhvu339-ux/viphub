local ESPFolder = Instance.new("Folder")
ESPFolder.Name = "BaconESP"
ESPFolder.Parent = game.CoreGui

local OriginalSizes = {}

--------------------------------------------------
-- RESET HITBOX

local function resetHitbox(plr)

    local char = plr.Character

    if char and char:FindFirstChild("HumanoidRootPart") then

        local hrp = char.HumanoidRootPart

        if OriginalSizes[plr] then
            hrp.Size = OriginalSizes[plr]
        else
            hrp.Size = Vector3.new(2,2,1)
        end

        hrp.Transparency = 1
        hrp.CanCollide = true
    end
end

--------------------------------------------------
-- APPLY HITBOX

local function applyHitbox(plr)

    local char = plr.Character

    if char and char:FindFirstChild("HumanoidRootPart") then

        local hrp = char.HumanoidRootPart

        if not OriginalSizes[plr] then
            OriginalSizes[plr] = hrp.Size
        end

        hrp.Size = Vector3.new(
            settings.HitboxSize,
            settings.HitboxSize,
            settings.HitboxSize
        )

        hrp.Transparency = 0.5
        hrp.CanCollide = false
    end
end

--------------------------------------------------
-- ESP

local function getESP(plr)
    return ESPFolder:FindFirstChild(plr.Name)
end

local function createESP(plr,enemy)

    if getESP(plr) then
        return
    end

    local hl = Instance.new("Highlight")

    hl.Name = plr.Name
    hl.Adornee = plr.Character
    hl.FillTransparency = 1
    hl.OutlineTransparency = 0
    hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop

    if enemy then
        hl.OutlineColor = Color3.fromRGB(255,0,0)
    else
        hl.OutlineColor = Color3.fromRGB(0,255,0)
    end

    hl.Parent = ESPFolder
end

local function removeESP(plr)

    local esp = getESP(plr)

    if esp then
        esp:Destroy()
    end
end

--------------------------------------------------
-- VISION LOOP

RunService.RenderStepped:Connect(function()

    for _,plr in pairs(Players:GetPlayers()) do

        if plr ~= player and plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") then

            local enemy = plr.Team ~= player.Team

            --------------------------------------------------
            -- HITBOX

            if settings.HitboxAll or (settings.HitboxTeam and enemy) then
                applyHitbox(plr)
            else
                resetHitbox(plr)
            end

            --------------------------------------------------
            -- ESP

            if settings.ESPAll or (settings.ESPTeam and enemy) then
                createESP(plr,enemy)
            else
                removeESP(plr)
            end
        end
    end
end)

--------------------------------------------------
-- CLEAN PLAYER

Players.PlayerRemoving:Connect(function(plr)

    removeESP(plr)

    OriginalSizes[plr] = nil
end)

